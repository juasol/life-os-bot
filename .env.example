# ===== 必須 =====
# Discord BOT トークン（Discord Developer Portal → Bot → Token）
DISCORD_TOKEN=

# Claude API キー（https://console.anthropic.com/）
ANTHROPIC_API_KEY=

# ===== スプレッドシート連携 =====
# スプレッドシート ID
GOOGLE_SHEET_ID=

# サービスアカウント認証。次のどちらか一方でよい:
#  (A) ローカル: credentials.json をフォルダ直下に置く（このとき下行は空でOK）
#  (B) クラウド/GitHub運用: credentials.json の中身(JSON)を1行にして下に貼る
#      例: GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_CREDENTIALS_JSON=

# ===== チャンネル名（Discord で作成したチャンネル名に合わせる）=====
# 未設定の場合は下記の既定値が使われる。
# 注: Discord はラテン文字を小文字化するが（AI秘書 → ai秘書）、BOT 側で吸収するのでこのままでよい。
CHANNEL_WEIGHT=体重
CHANNEL_TODO=今日やること
CHANNEL_REVIEW=振り返り
CHANNEL_MONEY=お金
CHANNEL_IDEA=アイデア
CHANNEL_ARTICLE=気になる記事
CHANNEL_ASSISTANT=AI秘書
CHANNEL_REPORT=レポート
CHANNEL_PROFILE=プロフィール
